<?xml version="1.0" encoding="UTF-8"?>
<data_package_template
    creator="Open Observer for OpenCPN"
    file_version="1"
    name="Default">

  <!-- Always generated by Open Observer. These folders are required. -->
  <always>
    <folder path="00_exports"/>
    <folder path="00_exports/metadata"/>
  </always>

  <!-- Created once per observation day under 01_daily_media/YYYY-MM-DD/. -->
  <daily_media>
    <folder name="photos" default="true"/>
    <folder name="audio" default="true"/>
    <folder name="video" default="true"/>
    <folder name="tracks" default="true"/>
    <folder name="nmea" default="true"/>
    <folder name="samples" default="true"/>
    <folder name="documents" default="true"/>
    <folder name="notes" default="true"/>
    <folder name="other" default="true"/>
  </daily_media>

  <!-- Generated raw-data exports. -->
  <raw_data>
    <folder path="00_exports/raw_data"/>
    <folder path="00_exports/raw_data/nmea" default="true"/>
    <folder path="00_exports/raw_data/tracks" default="true"/>
  </raw_data>

  <!-- Optional user working folders. -->
  <working>
    <folder path="02_working"/>
    <folder path="02_working/notes" default="true"/>
    <folder path="02_working/maps" default="true"/>
    <folder path="02_working/reports" default="true"/>
    <folder path="02_working/tables" default="true"/>
    <folder path="02_working/working_files" default="true"/>
  </working>

</data_package_template>