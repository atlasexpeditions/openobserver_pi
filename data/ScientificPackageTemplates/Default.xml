<?xml version="1.0" encoding="UTF-8"?>
<data_package_template
  creator="Open Observer for OpenCPN"
  file_version="1"
  name="Default">

  <!-- Always generated by Open Observer. These folders are required. -->
  <always>
    <folder path="00_raw-data"/>
    <folder path="00_raw-data/metadata"/>
    <folder path="00_raw-data/observations"/>
    <folder path="00_raw-data/nmea-recordings"/>
    <folder path="00_raw-data/tracks"/>
    <folder path="01_daily_media"/>
    <folder path="02_working"/>
  </always>

  <!-- Created once per observation day under 01_daily_media/YYYY-MM-DD/. -->
  <daily_media>
    <folder name="photos" default="true"/>
    <folder name="audio" default="true"/>
    <folder name="video" default="true"/>
    <folder name="tracks" default="true"/>
    <folder name="nmea" default="true"/>
    <folder name="samples" default="true"/>
  </daily_media>

  <!-- Generated raw-data exports. -->
  <raw_data>
    <folder path="00_raw-data/observations" default="true"/>
    <folder path="00_raw-data/nmea-recordings" default="true"/>
    <folder path="00_raw-data/tracks" default="true"/>
  </raw_data>

  <!-- Optional user working folder. -->
  <working>
    <folder path="02_working" default="true"/>
  </working>

</data_package_template>